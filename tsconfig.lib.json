{
  "compilerOptions": {
    "target": "es2023",
    "lib": [
      "ES2023",
      "DOM"
    ],
    "types": [
      "vite/client"
    ],
    "skipLibCheck": true,
    "rootDir": "./lib",

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "resolveJsonModule": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Imports lookup locations */
    "paths": {
      "assets/*": [
        "./lib/assets/*"
      ],
      "components/*": [
        "./lib/components/*"
      ],
      "context/*": [
        "./lib/context/*"
      ],
      "hooks/*": [
        "./lib/hooks/*"
      ],
      "queries/*": [
        "./lib/queries/*"
      ]
    }
  },
  "include": [
    "./lib"
  ]
}